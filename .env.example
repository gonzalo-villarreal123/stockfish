# ============================================================
# STOCKFISH — Variables de entorno
# Copiá este archivo, renombralo .env y completá los valores
# NUNCA subas el .env real al repositorio
# ============================================================

# ── Anthropic (Claude) ──────────────────────────────────────
# Consola: https://console.anthropic.com
# Usado en: apps/agents/graph.py (intake node)
ANTHROPIC_API_KEY=sk-ant-...

# ── Voyage AI (Embeddings) ──────────────────────────────────
# Consola: https://dash.voyageai.com
# Usado en: apps/agents/graph.py (style_rag node)
VOYAGE_API_KEY=pa-...

# ── Supabase ────────────────────────────────────────────────
# Consola: https://supabase.com/dashboard
# Usado en: apps/agents/graph.py y apps/agents/db.py
SUPABASE_REST_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_ANON_KEY=eyJ...

# ── Frontend (Next.js) ──────────────────────────────────────
# Usado en: apps/web/.env.local
NEXT_PUBLIC_AGENTS_URL=https://stockfish-agents.onrender.com
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── App ─────────────────────────────────────────────────────
PORT=8000
